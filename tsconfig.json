{
  "compilerOptions": {
    "target": "ES2025",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2025", "DOM"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    /* TypeScript 6 requires explicit types (defaults to [] now) */
    "types": [],

    /* Linting — strict is now default in TS6, but we keep it explicit for clarity */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"]
}
